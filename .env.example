ASSISTANT_NAME=Andy
WEB_UI_ENABLED=true
WEB_UI_PORT=3456

# OneCLI Agent Vault — manages credential injection into containers
ONECLI_URL=http://127.0.0.1:10254

# Custom Anthropic endpoint (optional — omit to use api.anthropic.com)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Service config (non-secret URLs and IDs passed through to containers)
# GITLAB_URL=https://gitlab.example.com
# HARNESS_ACCOUNT_ID=your-account-id
# BLACKDUCK_URL=https://your-instance.blackduck.com
# ATLASSIAN_BASE_URL=https://your-team.atlassian.net
# ATLASSIAN_EMAIL=you@example.com
